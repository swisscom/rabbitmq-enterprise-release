# Get the values from your vault
# (for internals: https://gitdata.scmgmt.net/cloud-native/services/rabbitmq-boshrelease-private-files)
#
# After filling in the values copy this file to config/private.yml
#
# This file is required to make `bosh upload blobs` work.
---
blobstore:
  provider: s3
  options:
    access_key_id: <aws-blobstore-access-key-id>
    secret_access_key: <aws-blobstore-secret-access-key>
